# Greenlight Coaching Portal - Environment Variables
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local

# =============================================================================
# REQUIRED
# =============================================================================

# Convex deployment URL (public, exposed to the browser)
# Get this from: https://dashboard.convex.dev → your project → Settings → URL
# Format: https://<project-slug>.convex.cloud
NEXT_PUBLIC_CONVEX_URL=

# =============================================================================
# DEPLOYMENT ONLY (Vercel / CI)
# =============================================================================

# Convex deployment name (used by `npx convex deploy` during CI builds)
# Get this from: https://dashboard.convex.dev → your project → Settings
# Format: <team>/<project>
# CONVEX_DEPLOYMENT=
